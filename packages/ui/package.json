{
  "name": "@emberchamber/ui",
  "version": "0.1.0",
  "private": true,
  "description": "EmberChamber design system — tokens, primitives, and shared Tailwind config",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "default": "./dist/tokens.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./tailwind": "./tailwind.config.js",
    "./tokens.css": "./dist/tokens.css"
  },
  "scripts": {
    "build": "tsc && node scripts/generate-tokens-css.mjs",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tailwindcss": "^3.4.17",
    "@types/react": "^18.3.3"
  }
}
