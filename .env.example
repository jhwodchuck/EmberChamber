# PrivateMesh Root Environment Configuration
# Copy to .env and fill in values

# JWT Secrets (REQUIRED in production - generate with: openssl rand -hex 64)
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string-in-production

# Frontend URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
CORS_ORIGIN=http://localhost:3000
