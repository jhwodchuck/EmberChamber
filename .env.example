# EmberChamber Beta v2
# Copy to .env before running the web companion and relay locally.

# ── Public origins ────────────────────────────────────────────────────────────
NEXT_PUBLIC_RELAY_URL=http://127.0.0.1:8787
NEXT_PUBLIC_WEB_URL=http://127.0.0.1:3000
EMBERCHAMBER_RELAY_PUBLIC_URL=http://127.0.0.1:8787
EMBERCHAMBER_WEB_PUBLIC_URL=http://127.0.0.1:3000
EMBERCHAMBER_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,https://tauri.localhost,http://tauri.localhost,tauri://localhost

# ── Beta access control ───────────────────────────────────────────────────────
EMBERCHAMBER_DEV_INVITE_TOKEN=dev-beta-invite

# ── Relay auth secrets (generate strong random values) ───────────────────────
EMBERCHAMBER_EMAIL_ENCRYPTION_SECRET=change-me-email-encryption-secret
EMBERCHAMBER_EMAIL_INDEX_SECRET=change-me-email-index-secret
EMBERCHAMBER_ACCESS_TOKEN_SECRET=change-me-access-token-secret
EMBERCHAMBER_REFRESH_TOKEN_SECRET=change-me-refresh-token-secret
EMBERCHAMBER_ATTACHMENT_TOKEN_SECRET=change-me-attachment-token-secret

# ── Email delivery abstraction ────────────────────────────────────────────────
EMBERCHAMBER_EMAIL_FROM=noreply@emberchamber.local
EMBERCHAMBER_EMAIL_PROVIDER=log

# ── Cloudflare local dev placeholders ────────────────────────────────────────
EMBERCHAMBER_D1_DB_ID=local-dev
EMBERCHAMBER_R2_BUCKET=emberchamber-attachments-dev

# ── Desktop shell ─────────────────────────────────────────────────────────────
EMBERCHAMBER_DESKTOP_RELAY_URL=http://127.0.0.1:8787
EMBERCHAMBER_DESKTOP_BETA_CHANNEL=closed-beta

# ── Legacy prototype stack (kept only while the new beta is scaffolded) ─────
DATABASE_URL=postgresql://emberchamber:emberchamber@localhost:5432/emberchamber
DB_PASSWORD=emberchamber
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=emberchamber
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
SESSION_SECRET=change-me-32-bytes-minimum-secret
