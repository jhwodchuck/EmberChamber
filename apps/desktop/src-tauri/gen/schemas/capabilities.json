  "default": {
    "identifier": "default",
    "description": "Default capability set for EmberChamber native windows.",
    "local": true,
    "windows": ["main"],
    "permissions": [
      "core:default",
      "core:window:allow-start-dragging",
      "core:window:allow-set-title",
      "core:window:allow-set-content-protected"
    ]
  }
}
