{
  "expo": {
    "name": "EmberChamber",
    "slug": "emberchamber-mobile",
    "scheme": "emberchamber",
    "version": "0.1.0-beta.15",
    "description": "Invite-only messaging for trusted circles.",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.emberchamber.mobile",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "blockedPermissions": ["android.permission.RECORD_AUDIO"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#140d10"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "emberchamber.com",
              "pathPrefix": "/invite/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "emberchamber.com",
              "path": "/auth/complete"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.emberchamber.mobile",
      "associatedDomains": [
        "applinks:emberchamber.com"
      ],
      "supportsTablet": false,
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "defaultChannel": "messages"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow EmberChamber to attach photos from your library."
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": true
        }
      ]
    ]
  }
}
