{
  "expo": {
    "name": "EmberChamber",
    "slug": "emberchamber-mobile",
    "scheme": "emberchamber",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.emberchamber.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#140d10"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "emberchamber.com",
              "pathPrefix": "/invite/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "emberchamber.com",
              "path": "/auth/complete"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.emberchamber.mobile",
      "supportsTablet": false,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow EmberChamber to attach photos from your library.",
          "cameraPermission": "Allow EmberChamber to take a photo for a secure conversation."
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow EmberChamber to access your Face ID for passkey-protected sessions."
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": true
        }
      ],
      [
        "expo-screen-capture"
      ]
    ],
    "extra": {
      "relayUrl": "http://10.0.2.2:8787"
    }
  }
}
