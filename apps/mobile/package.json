{
  "name": "@emberchamber/mobile",
  "version": "0.1.0-beta.24",
  "private": true,
  "main": "index.js",
  "scripts": {
    "android:patch-build": "node ./scripts/patch-react-native-gradle-plugin.js",
    "android:patch-release-config": "node ./scripts/patch-android-release-config.js",
    "dev": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "doctor": "expo-doctor",
    "verify": "npm run doctor && npm run type-check",
    "prebuild": "npm run android:patch-build && expo prebuild --platform android --clean --no-install && npm run android:patch-release-config",
    "prebuild:android:preserve-worktree": "node ./scripts/run-android-prebuild-preserving-worktree.js",
    "prebuild:ios": "expo prebuild --platform ios --clean --no-install",
    "build:android": "npm run android:patch-build && expo prebuild --platform android --no-install && npm run android:patch-release-config",
    "build:ios": "expo prebuild --platform ios --no-install",
    "verify:google-services": "node ./scripts/verify-google-services-file.js",
    "verify:android": "npm run doctor && npm run type-check && npm run prebuild:android:preserve-worktree",
    "type-check": "npm --prefix ../../packages/protocol run build && npm --prefix ../../packages/shared run build && npm --prefix ../../packages/ui run build && tsc --noEmit"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-get-random-values",
        "react-native-svg"
      ]
    }
  },
  "dependencies": {
    "@emberchamber/protocol": "^0.1.0",
    "@emberchamber/shared": "^0.1.0",
    "@emberchamber/ui": "^0.1.0",
    "expo": "~55.0.16",
    "expo-camera": "~55.0.16",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.17",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.19",
    "expo-intent-launcher": "~55.0.12",
    "expo-location": "~55.1.8",
    "expo-notifications": "~55.0.20",
    "expo-screen-capture": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-sqlite": "~55.0.15",
    "expo-system-ui": "~55.0.16",
    "expo-task-manager": "~55.0.15",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-get-random-values": "^2.0.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "^15.15.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "expo-doctor": "^1.18.15",
    "typescript": "^5.4.5"
  }
}
