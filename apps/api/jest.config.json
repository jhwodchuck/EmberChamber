{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src"],
  "testMatch": ["**/*.test.ts"],
  "moduleNameMapper": {
    "^@emberchamber/shared$": "<rootDir>/../../packages/shared/src/index.ts"
  },
  "collectCoverageFrom": ["src/**/*.ts", "!src/index.ts", "!src/db/migrate.ts"]
}
