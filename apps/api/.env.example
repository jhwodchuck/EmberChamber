# EmberChamber API Environment Configuration
# Copy this file to .env and fill in values

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://emberchamber:emberchamber@localhost:5432/emberchamber

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets - MUST be changed in production (use: openssl rand -hex 64)
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string-in-production

# CORS
CORS_ORIGIN=http://localhost:3000

# S3 / Object Storage
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET=emberchamber
# For local MinIO development:
S3_ENDPOINT=http://localhost:9000

# File upload limits
MAX_FILE_SIZE_MB=50
