# ---------------------------------------------------------------------------
# EmberChamber web — environment variables
#
# Copy this file to .env.local for local development.
# In production (Vercel) these are set as project environment variables.
# All NEXT_PUBLIC_ variables are inlined into the client bundle at build time;
# treat them as public but be sure they resolve correctly per environment.
# ---------------------------------------------------------------------------

# REQUIRED — public URL of the EmberChamber relay Cloudflare Worker.
# Used by both the client-side relay API client and by next.config.js to
# derive the Content-Security-Policy connect-src directive and the image
# remotePatterns allowlist.
# Production:  https://relay.emberchamber.com
# Staging:     https://relay-staging.emberchamber.com
# Development: http://127.0.0.1:8787
NEXT_PUBLIC_RELAY_URL=http://127.0.0.1:8787

# REQUIRED — canonical public URL of the web app itself.
# Used as the metadataBase in Next.js metadata, and for Open Graph / Twitter
# card image URLs.  Must not include a trailing slash.
# Production:  https://emberchamber.com
# Development: http://127.0.0.1:3000
NEXT_PUBLIC_WEB_URL=http://127.0.0.1:3000

# OPTIONAL — set to "true" to enable the email magic-link bootstrap path.
# When false the onboarding form shows a "not live yet" notice.
# Set to "true" in production once the relay email queue is wired.
# Set to "true" in CI for integration tests (see ci-web.yml screenshots job).
NEXT_PUBLIC_EMBERCHAMBER_AUTH_BOOTSTRAP_ENABLED=true

# OPTIONAL — set to "standalone" to enable Next.js standalone output mode
# for Docker / containerised deployments.  Leave unset for Vercel.
# NEXT_OUTPUT=standalone
